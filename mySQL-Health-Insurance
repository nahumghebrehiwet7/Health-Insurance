# The coding on this page shows all the mySQL codes used for the health insurance project

# Average Charge by Sex
select sex,
count(*),
avg(charges),
stddev(charges)
from insurance
group by sex 
order by avg(charges) desc; 


# Average charge by age
select
case
when age < 30 then "<30"
when age between 30 and 39 then "30-39"
when age between 40 and 49 then "40-49"
when age between 50 and 59 then "50-59"
else "60+"
end as age_Group,
count(*),
avg(charges)
from insurance
group by age_Group
order by avg(charges) desc;

# Average Charge by children count
select children,
count(*),
avg(charges),
stddev(charges)
from insurance
group by children
order by avg(charges) desc;

# Average Charge by children count (Removing patients with more than 3 children) 
select children,
count(*),
avg(charges),
stddev(charges)
from insurance
where children < 4
group by children
order by avg(charges) desc;

# Average Charge by BMI 
select
case
when bmi < 18.5 then "Underweight"
when bmi < 24.9 then "Healthy Weight" 
when bmi < 29.9 then "Overweight"
when bmi < 34.9 then "Class 1 Obesity"
when bmi < 39.9 then "Class 2 Obesity"
else "Class 3 Obesity"
end as bmi_Range,
avg(charges),
count(*),
stddev(charges)
from insurance
group by bmi_Range
order by avg(charges) desc;

# Average Charge by BMI (excluding underweight and class 3 obesity)
select
case
when bmi < 18.5 then "Underweight"
when bmi < 24.9 then "Healthy Weight" 
when bmi < 29.9 then "Overweight"
when bmi < 34.9 then "Class 1 Obesity"
when bmi < 39.9 then "Class 2 Obesity"
else "Class 3 Obesity"
end as bmi_Range,
avg(charges),
count(*),
stddev(charges)
from insurance
where bmi between 18.5 and 39.89
group by bmi_Range
order by avg(charges) desc;
