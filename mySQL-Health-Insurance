

# Average charge by age
select
case
when age < 30 then "<30"
when age between 30 and 39 then "30-39"
when age between 40 and 49 then "40-49"
when age between 50 and 59 then "50-59"
else "60+"
end as age_Group,
count(*),
avg(charges)
from insurance
group by age_Group
order by avg(charges) desc;

# Average Charge by children count
select children,
count(*),
avg(charges),
stddev(charges)
from insurance
group by children
order by avg(charges) desc;
